{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha"],
    "outDir": "dist"
  },
  "include": ["./hardhat.config.ts", "./test/**/*.ts", "./scripts/**/*.ts"]
}
