// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model - maps Privy users to their wallet addresses
model User {
  id            String    @id // Privy user ID
  walletAddress String    @unique // The embedded wallet address (hidden from UI)
  fullName      String    // Display name in Hebrew
  phoneSuffix   String    // Last 4 digits of phone number
  avatarColor   String    // Tailwind class like "bg-blue-600"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business? // Optional business account

  @@map("users")
}

// Business model - for business accounts
model Business {
  id              String   @id @default(cuid())
  userId          String   @unique // Owner's Privy user ID
  user            User     @relation(fields: [userId], references: [id])
  businessName    String   // שם העסק
  businessType    String   // סוג העסק (מסעדה, חנות, שירותים וכו')
  businessNumber  String?  // מספר עוסק/ח.פ
  phone           String   // טלפון העסק
  address         String?  // כתובת
  description     String?  // תיאור קצר
  logoColor       String   // צבע לוגו/אוואטר
  isApproved      Boolean  @default(false) // האם העסק אושר
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("businesses")
}
